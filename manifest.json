{
  "manifest_version": 3,
  "name": "IR Scholar: Dual-Model Researcher",
  "version": "1.3",
  "description": "Comparative geopolitical analysis using Gemini and DeepSeek side-by-side.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*"
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html"
  }
}